<Window
    x:Class="SttClient.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="STT Client">

    <Grid Padding="16" RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8">
            <Button x:Name="PauseButton"
                    Click="PauseButton_Click"
                    Content="Pause / Resume"/>
            <ToggleButton x:Name="InsertionToggle"
                          Content="Insert Text"
                          Click="InsertionToggle_Click"/>
        </StackPanel>

        <!-- Transcript area -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock x:Name="FinalizedTextBlock"
                           Text="{x:Bind ViewModel.FinalizedText, Mode=OneWay}"
                           TextWrapping="Wrap"
                           IsTextSelectionEnabled="True"/>
                <TextBlock x:Name="PartialTextBlock"
                           Text="{x:Bind ViewModel.PartialText, Mode=OneWay}"
                           TextWrapping="Wrap"
                           Opacity="0.5"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Status bar -->
        <TextBlock Grid.Row="2"
                   x:Name="StatusText"
                   FontSize="11"
                   Opacity="0.6"/>
    </Grid>
</Window>
